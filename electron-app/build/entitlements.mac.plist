<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron uses V8 JIT, which needs writable+executable memory.
       Required under Hardened Runtime or the renderer crashes on launch. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- The bundled Scala Native proxy binary is spawned as a child process. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <!-- The proxy listens on a local socket and makes outbound HTTPS calls. -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
</dict>
</plist>
